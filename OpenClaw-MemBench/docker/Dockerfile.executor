# 直接使用你本地已有的镜像，不拉取任何外网资源
FROM openclaw-membench-openclaw:latest

# 环境变量（保持不变）
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

# 修复 python3 命令找不到的问题（关键！）
RUN ln -s /usr/local/bin/python /usr/bin/python3 || true
RUN ln -s python /usr/bin/python3 || true
# 进入工作目录
WORKDIR /root

# 把你的项目代码复制进镜像
COPY OpenClaw-MemBench /root/OpenClaw-MemBench

# 进入项目目录
WORKDIR /root/OpenClaw-MemBench