FROM openclaw-membench-openclaw:latest


ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

RUN apt-get update \
    && apt-get install -y --no-install-recommends python3 python3-pip bash ca-certificates curl git \
    && rm -rf /var/lib/apt/lists/*

# Install OpenClaw CLI from npm (pin to the version available in registry)
RUN npm install -g openclaw@2026.4.15

WORKDIR /root
