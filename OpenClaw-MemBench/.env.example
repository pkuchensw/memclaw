# OpenClaw-MemBench Environment Configuration

# ===================== API Configuration =====================

# Base URL for LLM API (OpenAI-compatible)
OPENCLAW_BASE_URL=http://127.0.0.1:18789
OPENCLAW_CHAT_COMPLETIONS_PATH=/v1/chat/completions
OPENCLAW_API_KEY=your-api-key-here
OPENCLAW_API_PROVIDER=openai

# Model selection
OPENCLAW_MODEL=anthropic/claude-sonnet-4-5

# Request settings
OPENCLAW_TEMPERATURE=0
OPENCLAW_MAX_TOKENS=2048
OPENCLAW_VERIFY_SSL=true

# Timeout and retry settings
OPENCLAW_REQUEST_TIMEOUT=0
OPENCLAW_CONNECT_TIMEOUT=10
OPENCLAW_READ_TIMEOUT=900
OPENCLAW_MAX_RETRIES=4
OPENCLAW_RETRY_BASE_SECONDS=3
OPENCLAW_TASK_MAX_ATTEMPTS=3
OPENCLAW_TASK_RETRY_BASE_SECONDS=5

# ===================== LCM (Context Compression) Configuration =====================

# LCM API endpoint (for real LCM integration)
OPENCLAW_LCM_BASE_URL=http://127.0.0.1:18790
OPENCLAW_LCM_API_KEY=
OPENCLAW_LCM_TIMEOUT=60

# Context compression settings
OPENCLAW_CONTEXT_PROFILE=full
OPENCLAW_CONTEXT_BUDGET_CHARS=12000
OPENCLAW_COMPRESSION_METHOD=lcm-proxy

# Available compression methods:
# - full: No compression, use complete context
# - lcm-proxy: Two-layer summary (signal + recent tail)
# - sliding-window: Keep only most recent characters
# - keyword: Keep keyword-dense lines
# - episode: Episode-level digest

# ===================== Runtime Configuration =====================

# Execution runtime: api | docker | openclaw-docker
OPENCLAW_RUNTIME=api

# Fallback settings
OPENCLAW_ENABLE_API_FALLBACK=true
OPENCLAW_ENABLE_WARMUP=false

# ===================== Docker Configuration =====================

# Docker image settings
DOCKER_IMAGE=openclaw-membench-executor:latest
DOCKER_NETWORK=host
DOCKER_EXTRA_ARGS=
DOCKER_WORKSPACE_MOUNT=/tmp_workspace
DOCKER_OUTPUT_MOUNT=/tmp_output
DOCKER_CONTAINER_PREFIX=membench
DOCKER_PYTHON_BIN=python
DOCKER_CLEAR_PROXY=true

# Proxy settings for Docker
DOCKER_HTTP_PROXY=
DOCKER_HTTPS_PROXY=
DOCKER_NO_PROXY=

# ===================== OpenClaw Docker Runtime =====================

OPENCLAW_DOCKER_IMAGE=openclaw-membench-openclaw:latest
OPENCLAW_DOCKER_NETWORK=host
OPENCLAW_DOCKER_EXTRA_ARGS=
OPENCLAW_DOCKER_CLEAR_PROXY=true
OPENCLAW_DOCKER_HIDE_PATTERNS=oracle.yaml,grader.py,gt,answers,solution,expected
OPENCLAW_DOCKER_PRESERVE_CONTAINER=false
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_THINKING_DEFAULT=

# Proxy settings for OpenClaw Docker
OPENCLAW_DOCKER_HTTP_PROXY=
OPENCLAW_DOCKER_HTTPS_PROXY=
OPENCLAW_DOCKER_NO_PROXY=

# ===================== Cost Estimation =====================

# Price per 1M tokens (for cost estimation in usage.json)
OPENCLAW_PRICE_INPUT_PER_1M=3.0
OPENCLAW_PRICE_OUTPUT_PER_1M=15.0

# ===================== Directory Configuration =====================

TASKS_SUBDIR=tasks
OUTPUT_SUBDIR=outputs
