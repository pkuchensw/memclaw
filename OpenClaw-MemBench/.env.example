# OpenClaw runtime
OPENCLAW_BASE_URL=http://127.0.0.1:18789
OPENCLAW_MODEL=anthropic/claude-sonnet-4-5
OPENCLAW_API_KEY=
OPENCLAW_CHAT_COMPLETIONS_PATH=/v1/chat/completions
OPENCLAW_API_PROVIDER=openai
OPENCLAW_TEMPERATURE=0
OPENCLAW_MAX_TOKENS=2048
OPENCLAW_REQUEST_TIMEOUT=0
OPENCLAW_MAX_RETRIES=4
OPENCLAW_RETRY_BASE_SECONDS=3
OPENCLAW_CONTEXT_PROFILE=full
OPENCLAW_CONTEXT_BUDGET_CHARS=12000
OPENCLAW_PRICE_INPUT_PER_1M=0
OPENCLAW_PRICE_OUTPUT_PER_1M=0
OPENCLAW_VERIFY_SSL=true
OPENCLAW_RUNTIME=api
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_THINKING_DEFAULT=

# Docker isolated runtime (used when OPENCLAW_RUNTIME=docker)
DOCKER_IMAGE=openclaw-membench-executor:latest
DOCKER_NETWORK=host
DOCKER_WORKSPACE_MOUNT=/tmp_workspace
DOCKER_OUTPUT_MOUNT=/tmp_output
DOCKER_CONTAINER_PREFIX=membench
DOCKER_PYTHON_BIN=python3
DOCKER_CLEAR_PROXY=true
DOCKER_HTTP_PROXY=
DOCKER_HTTPS_PROXY=
DOCKER_NO_PROXY=
DOCKER_EXTRA_ARGS=

# Real OpenClaw isolated runtime (used when OPENCLAW_RUNTIME=openclaw-docker)
OPENCLAW_DOCKER_IMAGE=openclaw-membench-openclaw:latest
OPENCLAW_DOCKER_NETWORK=host
OPENCLAW_DOCKER_CLEAR_PROXY=true
OPENCLAW_DOCKER_HTTP_PROXY=
OPENCLAW_DOCKER_HTTPS_PROXY=
OPENCLAW_DOCKER_NO_PROXY=
OPENCLAW_DOCKER_EXTRA_ARGS=
OPENCLAW_DOCKER_HIDE_PATTERNS=oracle.yaml,grader.py,gt,answers,solution,expected
OPENCLAW_DOCKER_PRESERVE_CONTAINER=false

# Benchmark runtime
TASKS_SUBDIR=tasks
WORKSPACE_SUBDIR=workspace
OUTPUT_SUBDIR=outputs
DEFAULT_PARALLEL=1
