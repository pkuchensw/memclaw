# Optional Anthropic-compatible aliases (kept for compatibility)
ANTHROPIC_BASE_URL=https://api.moonshot.cn/anthropic
ANTHROPIC_AUTH_TOKEN=sk-u8BNPep9geVBIPEQmDYd6QGdPqvpFcuqw2K2mUGkdUMdLmY8
ANTHROPIC_MODEL=kimi-k2.5
ANTHROPIC_DEFAULT_HAIKU_MODEL=kimi-k2.5
ANTHROPIC_DEFAULT_SONNET_MODEL=kimi-k2.5
ANTHROPIC_DEFAULT_OPUS_MODEL=kimi-k2.5

# Runner-mapped config (do not change code, only env)
OPENCLAW_BASE_URL=https://api.moonshot.cn/v1
OPENCLAW_API_KEY=sk-u8BNPep9geVBIPEQmDYd6QGdPqvpFcuqw2K2mUGkdUMdLmY8
OPENCLAW_MODEL=kimi-k2.5
OPENCLAW_CHAT_COMPLETIONS_PATH=/chat/completions
OPENCLAW_API_PROVIDER=openai
OPENCLAW_TEMPERATURE=1
OPENCLAW_MAX_TOKENS=8092
OPENCLAW_REQUEST_TIMEOUT=90
OPENCLAW_MAX_RETRIES=1
OPENCLAW_RETRY_BASE_SECONDS=2
OPENCLAW_CONTEXT_PROFILE=full
OPENCLAW_CONTEXT_BUDGET_CHARS=12000
OPENCLAW_PRICE_INPUT_PER_1M=0
OPENCLAW_PRICE_OUTPUT_PER_1M=0
OPENCLAW_VERIFY_SSL=true
OPENCLAW_RUNTIME=api

# Benchmark runtime
TASKS_SUBDIR=tasks
WORKSPACE_SUBDIR=workspace
OUTPUT_SUBDIR=outputs
DEFAULT_PARALLEL=1

# Docker runtime defaults (inactive when OPENCLAW_RUNTIME=api)
DOCKER_IMAGE=openclaw-membench-executor:latest
DOCKER_NETWORK=host
DOCKER_WORKSPACE_MOUNT=/tmp_workspace
DOCKER_OUTPUT_MOUNT=/tmp_output
DOCKER_CONTAINER_PREFIX=membench
DOCKER_PYTHON_BIN=python3
DOCKER_CLEAR_PROXY=true
DOCKER_HTTP_PROXY=http://star-proxy.oa.com:3128
DOCKER_HTTPS_PROXY=http://star-proxy.oa.com:3128
DOCKER_NO_PROXY=localhost,127.0.0.1
DOCKER_EXTRA_ARGS=
