{
  "task_id": "03_Procedure_Transfer_task_12_log_triage_pattern_reuse",
  "status": "completed",
  "procedure": {
    "name": "Log Triage Pattern Reuse",
    "version": "1.0.0",
    "description": "Standardized approach for analyzing and triaging system logs with reusable patterns",
    "steps": [
      {
        "id": "step_1",
        "name": "Log Collection",
        "description": "Gather logs from specified sources with consistent formatting",
        "commands": [
          "find /var/log -name '*.log' -mtime -1",
          "journalctl --since '1 hour ago' --no-pager",
          "dmesg -T | tail -100"
        ],
        "output_format": "timestamp,level,source,message"
      },
      {
        "id": "step_2", 
        "name": "Severity Classification",
        "description": "Categorize log entries by severity level",
        "patterns": {
          "critical": ["FATAL", "CRITICAL", "PANIC", "EMERGENCY"],
          "error": ["ERROR", "ERR", "EXCEPTION"],
          "warning": ["WARN", "WARNING", "ALERT"],
          "info": ["INFO", "INFORMATION"],
          "debug": ["DEBUG", "TRACE"]
        }
      },
      {
        "id": "step_3",
        "name": "Pattern Matching",
        "description": "Identify common error patterns and known issues",
        "patterns": {
          "out_of_memory": ["Out of memory", "OOM", "memory allocation failed"],
          "disk_full": ["No space left", "Disk full", "ENOSPC"],
          "permission_denied": ["Permission denied", "EACCES", "access denied"],
          "connection_refused": ["Connection refused", "ECONNREFUSED", "Connection reset"],
          "timeout": ["Timeout", "ETIMEDOUT", "Connection timed out"]
        }
      },
      {
        "id": "step_4",
        "name": "Triage Decision",
        "description": "Make triage decisions based on severity and pattern analysis",
        "rules": [
          "Critical errors require immediate investigation",
          "Connection timeouts may indicate network issues",
          "Permission errors suggest access control problems",
          "Memory issues require resource monitoring"
        ]
      }
    ],
    "reusability": {
      "parameters": ["log_source", "time_range", "severity_threshold"],
      "output_formats": ["json", "csv", "text_summary"],
      "integration_points": ["monitoring_systems", "alerting_pipelines", "dashboards"]
    }
  },
  "timestamp": "2024-04-19T01:32:51Z",
  "output_dir": "/tmp_workspace/results"
}